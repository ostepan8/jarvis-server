# ─── AI Providers ───────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Lighting ───────────────────────────────────────────────────────
# Backend: "phillips_hue" or "yeelight"
LIGHTING_BACKEND=phillips_hue
PHILLIPS_HUE_BRIDGE_IP=192.168.1.50
PHILLIPS_HUE_USERNAME=your-hue-username-here
YEELIGHT_BULB_IPS=192.168.1.100,192.168.1.101

# ─── Roku ───────────────────────────────────────────────────────────
ROKU_IP_ADDRESS=192.168.1.150
ROKU_USERNAME=your-roku-username-here
ROKU_PASSWORD=your-roku-password-here

# ─── Calendar ───────────────────────────────────────────────────────
CALENDAR_API_URL=http://localhost:8080

# ─── Weather ────────────────────────────────────────────────────────
WEATHER_API_KEY=your-weather-api-key-here

# ─── Search ─────────────────────────────────────────────────────────
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# ─── Security ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-jwt-secret-key-here
# Generate with: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
CONFIG_SECRET=your-32-byte-base64-config-secret-here

# ─── Server ─────────────────────────────────────────────────────────
JARVIS_RESPONSE_TIMEOUT=15.0
JARVIS_LOG_LEVEL=INFO
JARVIS_VERBOSE=false

# Comma-separated list of allowed CORS origins (leave empty for defaults)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ───────────────────────────────────────────────────────
# Docker Compose sets these automatically via environment overrides.
# Only set manually for non-Docker deployments.
# AUTH_DB_PATH=auth.db
# LOG_DB_PATH=jarvis_logs.db
# PROTOCOLS_DB_PATH=protocols.db
# PERF_LOG_PATH=perf_logs.jsonl

MONGO_URI=mongodb://localhost:27017/
# When using Docker Compose with --profile mongo:
# MONGO_URI=mongodb://mongo:27017/
MONGO_DB_NAME=protocol

RECORD_NETWORK_METHODS=false

# ─── Misc ───────────────────────────────────────────────────────────
# Default user ID for CLI/local requests (defaults to 1 if not set)
DEFAULT_USER_ID=1
